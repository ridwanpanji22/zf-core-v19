# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=zfcore
DB_USER=zfcore
DB_PASSWORD=changeme

# Redis (REDIS_PASSWORD wajib — tidak ada fallback default)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD_HERE@redis:6379/0
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# OKX API (system-level, untuk data ingestion)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://zf.yourdomain.com/api/auth/google/callback

# Super Admin
SUPER_ADMIN_EMAIL=admin@example.com

# API Key Encryption
API_KEY_ENCRYPTION_SECRET=changeme-32-byte-random-string

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Auth
JWT_SECRET=changeme-to-random-string
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# App
APP_ENV=production
LOG_LEVEL=INFO
ASSET_SWARM_SIZE=200
DEMO_ENABLED=true
DEMO_INITIAL_BALANCE=10000
DEMO_MAX_LEVERAGE=10

# CORS
CORS_ORIGINS=["https://zf.yourdomain.com"]

# Frontend
NEXT_PUBLIC_API_URL=https://zf.yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://wszf.yourdomain.com
